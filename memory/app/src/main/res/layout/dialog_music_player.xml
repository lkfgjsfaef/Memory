<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/white">

    <!-- Header: title + close -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="音乐播放器"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/music_random_toggle"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="🔀 随机"
            android:textSize="12sp"
            android:textColor="#666"
            android:gravity="center"
            android:paddingHorizontal="10dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/spinner_bg"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/music_dialog_close"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="✕"
            android:textSize="18sp"
            android:textColor="#999"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless" />
    </LinearLayout>

    <!-- Current song info (when playing) -->
    <LinearLayout
        android:id="@+id/music_now_playing"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/music_dialog_thumb"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:scaleType="centerCrop"
            android:contentDescription="歌曲封面"
            android:background="@drawable/image_placeholder" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/music_dialog_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/music_dialog_artist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

    <!-- SeekBar row -->
    <LinearLayout
        android:id="@+id/music_seekbar_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="8dp"
        android:visibility="gone">

        <SeekBar
            android:id="@+id/music_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progressTint="@color/primary"
            android:thumbTint="@color/primary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/music_current_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0:00"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/music_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Playback controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <ImageButton
            android:id="@+id/music_prev_btn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_prev"
            android:contentDescription="上一首" />

        <ImageButton
            android:id="@+id/music_play_pause_btn"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/btn_primary_gradient"
            android:src="@drawable/ic_play"
            android:contentDescription="播放/暂停"
            android:layout_marginHorizontal="20dp" />

        <ImageButton
            android:id="@+id/music_next_btn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_next"
            android:contentDescription="下一首" />
    </LinearLayout>

    <!-- Search bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <EditText
            android:id="@+id/music_search_input"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:hint="搜索歌曲..."
            android:textSize="14sp"
            android:paddingHorizontal="12dp"
            android:background="@drawable/spinner_bg"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:maxLines="1" />

        <TextView
            android:id="@+id/music_search_btn"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="搜索"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:layout_marginStart="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/btn_primary_gradient" />
    </LinearLayout>

    <!-- Section label -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/music_section_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="播放列表"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/music_tab_toggle"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:text="搜索结果"
            android:textSize="11sp"
            android:textColor="#666"
            android:gravity="center"
            android:paddingHorizontal="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/spinner_bg_small" />
    </LinearLayout>

    <!-- Song list container (fixed height for stable layout) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:layout_marginBottom="12dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/music_song_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- No content placeholder -->
        <TextView
            android:id="@+id/music_empty_text"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="播放列表为空\n搜索歌曲并添加到列表吧~"
            android:textColor="@color/text_hint"
            android:textSize="14sp"
            android:gravity="center"
            android:background="@color/white" />
    </FrameLayout>

</LinearLayout>
